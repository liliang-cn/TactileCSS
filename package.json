{
  "name": "tactile-css",
  "version": "0.1.0",
  "description": "A physics-based CSS design system with tangible depth and tactile interactions",
  "main": "dist/tactile.css",
  "style": "dist/tactile.min.css",
  "files": [
    "dist",
    "tailwind-plugin"
  ],
  "scripts": {
    "build:css": "postcss src/index.css -o dist/tactile.css",
    "build:min": "cleancss -o dist/tactile.min.css dist/tactile.css",
    "build": "npm run build:css && npm run build:min",
    "watch": "postcss src/index.css -o dist/tactile.css -w",
    "dev": "npm run watch"
  },
  "keywords": [
    "css",
    "3d",
    "tactile",
    "neumorphism",
    "design-system",
    "tailwind",
    "ui"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "postcss": "^8.4.35",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.0.1",
    "postcss-nested": "^6.0.1"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.4.0"
  }
}
