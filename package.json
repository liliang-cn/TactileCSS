{
  "name": "tactile-css",
  "version": "0.1.0",
  "description": "A minimal neumorphic CSS library with outer, inner, and clay shadow styles",
  "main": "dist/tactile.css",
  "style": "dist/tactile.min.css",
  "homepage": "https://liliang-cn.github.io/TactileCSS",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liliang-cn/TactileCSS.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "exports": {
    ".": "./dist/tactile.css",
    "./css": "./dist/tactile.css",
    "./css.min": "./dist/tactile.min.css",
    "./tailwind": "./src/tailwind-plugin.js"
  },
  "files": [
    "dist",
    "src/tailwind-plugin.js"
  ],
  "scripts": {
    "build": "postcss src/index.css -o dist/tactile.css && cleancss -o dist/tactile.min.css dist/tactile.css",
    "watch": "postcss src/index.css -o dist/tactile.css -w"
  },
  "keywords": [
    "css",
    "neumorphism",
    "neumorphic",
    "soft-ui",
    "shadow",
    "ui",
    "claymorphism",
    "clay",
    "tailwind",
    "tailwindcss",
    "design-system"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "tailwindcss": ">=3.0.0"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "postcss": "^8.4.35",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "tailwindcss": "^4.2.1"
  }
}
